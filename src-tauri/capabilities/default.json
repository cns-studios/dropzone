{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:path:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        "https://shareit.cns-studios.com",
        "http://localhost:*",
        "http://127.0.0.1:*"
      ]
    },
    "opener:default",
    "shell:default",
    "shell:allow-open"
  ]
}