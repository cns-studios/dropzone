FROM golang:1.21-alpine AS builder

WORKDIR /app

RUN apk add --no-cache gcc musl-dev

COPY go.mod ./
RUN go mod download
COPY . .

RUN go build -o dropzone-api main.go handlers.go models.go
RUN go build -o dropzone-admin admin_cli.go models.go

FROM alpine:latest
WORKDIR /app

RUN apk add --no-cache ca-certificates

COPY --from=builder /app/dropzone-api .
COPY --from=builder /app/dropzone-admin .

RUN mkdir -p /app/uploads

EXPOSE 8080
CMD ["./dropzone-api"]